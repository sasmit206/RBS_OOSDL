<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hotel.controller.MainController"
            styleClass="root" minWidth="960" minHeight="620">

    <!-- ══════════ SIDEBAR ══════════ -->
    <left>
        <VBox styleClass="sidebar" spacing="4" minWidth="200" maxWidth="200">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" spacing="2">
                <Label text="🏨" style="-fx-font-size:28px;"/>
                <Label text="HotelManager" styleClass="sidebar-brand-name"/>
                <Label text="v3.0" styleClass="sidebar-brand-version"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>
            <Label text="NAVIGATION" styleClass="sidebar-section-label"/>

            <!-- Nav Buttons -->
            <Button fx:id="btnNavDashboard" text="  📊   Dashboard"
                    onAction="#showDashboard" maxWidth="Infinity"
                    styleClass="nav-btn, nav-btn-active"/>
            <Button fx:id="btnNavRooms" text="  🛏   Rooms"
                    onAction="#showRooms" maxWidth="Infinity"
                    styleClass="nav-btn"/>
            <Button fx:id="btnNavBookings" text="  📋   Bookings"
                    onAction="#showBookings" maxWidth="Infinity"
                    styleClass="nav-btn"/>

            <Pane VBox.vgrow="ALWAYS"/>
            <Separator styleClass="sidebar-separator"/>

            <!-- Status indicator -->
            <VBox styleClass="sidebar-status" spacing="4">
                <Label text="● CONNECTED" styleClass="status-online"/>
                <Label text="SQLite  ·  hotel.db" styleClass="status-db"/>
            </VBox>

        </VBox>
    </left>

    <!-- ══════════ CONTENT AREA ══════════ -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">

            <!-- ─── DASHBOARD ──────────────────────────── -->
            <VBox fx:id="dashboardPane" styleClass="content-pane" spacing="24">

                <VBox spacing="4">
                    <Label text="Dashboard" styleClass="page-title"/>
                    <Label text="Hotel overview at a glance" styleClass="page-subtitle"/>
                </VBox>

                <!-- Stat cards row — 5 cards including Revenue -->
                <HBox spacing="14">
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL ROOMS" styleClass="stat-label"/>
                        <Label fx:id="txtTotalRooms" text="0" styleClass="stat-number-neutral"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="AVAILABLE" styleClass="stat-label"/>
                        <Label fx:id="txtAvailableRooms" text="0" styleClass="stat-number-green"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="BOOKED" styleClass="stat-label"/>
                        <Label fx:id="txtBookedRooms" text="0" styleClass="stat-number-red"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="ACTIVE BOOKINGS" styleClass="stat-label"/>
                        <Label fx:id="txtActiveBookings" text="0" styleClass="stat-number-green"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL REVENUE" styleClass="stat-label"/>
                        <Label fx:id="txtTotalRevenue" text="0.00" styleClass="stat-number-green"/>
                    </VBox>
                </HBox>

                <!-- Quick-action Cards -->
                <HBox spacing="16">
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="🛏  Manage Rooms" styleClass="card-title"/>
                        <Label text="Add new rooms and view all current inventory."
                               styleClass="card-desc" wrapText="true"/>
                        <Button text="Go to Rooms →" onAction="#showRooms"
                                styleClass="btn-primary" maxWidth="160"/>
                    </VBox>
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="📋  Manage Bookings" styleClass="card-title"/>
                        <Label text="Book a room for a guest or process a checkout."
                               styleClass="card-desc" wrapText="true"/>
                        <Button text="Go to Bookings →" onAction="#showBookings"
                                styleClass="btn-primary" maxWidth="160"/>
                    </VBox>
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="💰  Revenue" styleClass="card-title"/>
                        <Label text="Total earnings from all confirmed bookings."
                               styleClass="card-desc" wrapText="true"/>
                        <Label fx:id="lblRevenueSummary" text="0.00"
                               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#00C853;"/>
                    </VBox>
                </HBox>

            </VBox>

            <!-- ─── ROOMS ───────────────────────────────── -->
            <VBox fx:id="roomsPane" styleClass="content-pane" spacing="20" visible="false" managed="false">

                <VBox spacing="4">
                    <Label text="Room Management" styleClass="page-title"/>
                    <Label text="Add and search rooms in your inventory" styleClass="page-subtitle"/>
                </VBox>

                <HBox spacing="16" VBox.vgrow="ALWAYS">

                    <!-- Left: Add Room card -->
                    <VBox styleClass="card form-card" spacing="0" minWidth="250" maxWidth="270">
                        <Label text="Add New Room" styleClass="card-title"/>
                        <Label text="Fill in all fields to add a room." styleClass="card-desc"/>
                        <Separator style="-fx-padding:10 0 14 0;"/>

                        <Label text="Room Number *" styleClass="form-label"/>
                        <TextField fx:id="tfRoomNumber" promptText="e.g. 101"
                                   styleClass="form-input"/>
                        <Label fx:id="errRoomNumber" text="" styleClass="form-error" managed="false" visible="false"/>

                        <Label text="Room Type *" styleClass="form-label"/>
                        <ComboBox fx:id="cbRoomType" promptText="Select type"
                                  maxWidth="Infinity" styleClass="combo-box"/>
                        <Label fx:id="errRoomType" text="" styleClass="form-error" managed="false" visible="false"/>

                        <Label text="Price / Night ($) *" styleClass="form-label"/>
                        <TextField fx:id="tfRoomPrice" promptText="e.g. 120.00"
                                   styleClass="form-input"/>
                        <Label fx:id="errRoomPrice" text="" styleClass="form-error" managed="false" visible="false"/>

                        <VBox style="-fx-padding: 16 0 0 0;" spacing="8">
                            <Button fx:id="btnAddRoom" text="＋  Add Room"
                                    onAction="#handleAddRoom"
                                    maxWidth="Infinity" styleClass="btn-primary"/>
                            <Button text="Clear" onAction="#handleClearRoomForm"
                                    maxWidth="Infinity" styleClass="btn-outline"/>
                        </VBox>
                    </VBox>

                    <!-- Right: Table card -->
                    <VBox styleClass="card table-card" spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="All Rooms" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="tfRoomSearch" promptText="🔍  Search rooms…"
                                       styleClass="search-input" prefWidth="200"
                                       onKeyReleased="#handleSearchRooms"/>
                            <Button text="✖" onAction="#handleClearSearch"
                                    styleClass="btn-outline-sm" prefWidth="32" prefHeight="32"/>
                        </HBox>
                        <TableView fx:id="roomTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                            <columns>
                                <TableColumn fx:id="colRoomNumber" text="Room #"        prefWidth="85"  sortable="true"/>
                                <TableColumn fx:id="colRoomType"   text="Type"          prefWidth="120" sortable="true"/>
                                <TableColumn fx:id="colRoomPrice"  text="Price / Night" prefWidth="140" sortable="true"/>
                                <TableColumn fx:id="colRoomStatus" text="Status"        prefWidth="120" sortable="true"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="🛏" style="-fx-font-size:32px;"/>
                                    <Label text="No rooms found" styleClass="empty-title"/>
                                    <Label text="Add a room using the form on the left."
                                           styleClass="empty-desc"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ─── BOOKINGS ─────────────────────────────── -->
            <VBox fx:id="bookingsPane" styleClass="content-pane" spacing="20" visible="false" managed="false">

                <VBox spacing="4">
                    <Label text="Bookings" styleClass="page-title"/>
                    <Label text="Create reservations and manage checkouts" styleClass="page-subtitle"/>
                </VBox>

                <HBox spacing="16" VBox.vgrow="ALWAYS">

                    <!-- Left: Forms -->
                    <VBox spacing="14" minWidth="270" maxWidth="290">

                        <!-- Book form -->
                        <VBox styleClass="card form-card" spacing="0">
                            <Label text="New Booking" styleClass="card-title"/>
                            <Label text="Reserve an available room for a guest." styleClass="card-desc"/>
                            <Separator style="-fx-padding:10 0 14 0;"/>

                            <Label text="Customer Name *" styleClass="form-label"/>
                            <TextField fx:id="tfCustomerName" promptText="Full name"
                                       styleClass="form-input"/>
                            <Label fx:id="errCustomerName" text="" styleClass="form-error" managed="false" visible="false"/>

                            <Label text="Room Number *" styleClass="form-label"/>
                            <TextField fx:id="tfBookRoomNumber" promptText="e.g. 201"
                                       styleClass="form-input"/>
                            <Label fx:id="errBookRoomNumber" text="" styleClass="form-error" managed="false" visible="false"/>

                            <Label text="Check-in Date *" styleClass="form-label"/>
                            <DatePicker fx:id="dpCheckIn" maxWidth="Infinity" styleClass="date-picker"/>
                            <Label fx:id="errCheckIn" text="" styleClass="form-error" managed="false" visible="false"/>

                            <Label text="Check-out Date *" styleClass="form-label"/>
                            <DatePicker fx:id="dpCheckOut" maxWidth="Infinity" styleClass="date-picker"/>
                            <Label fx:id="errCheckOut" text="" styleClass="form-error" managed="false" visible="false"/>

                            <VBox style="-fx-padding: 14 0 0 0;">
                                <Button fx:id="btnBookRoom" text="✅  Confirm Booking"
                                        onAction="#handleBookRoom"
                                        maxWidth="Infinity" styleClass="btn-primary"/>
                            </VBox>
                        </VBox>

                        <!-- Checkout form -->
                        <VBox styleClass="card form-card" spacing="0">
                            <Label text="Checkout" styleClass="card-title"/>
                            <Label text="Mark a room as available again." styleClass="card-desc"/>
                            <Separator style="-fx-padding:10 0 14 0;"/>

                            <Label text="Room Number *" styleClass="form-label"/>
                            <TextField fx:id="tfCheckoutRoomNumber" promptText="e.g. 201"
                                       styleClass="form-input"/>
                            <Label fx:id="errCheckoutRoom" text="" styleClass="form-error" managed="false" visible="false"/>

                            <VBox style="-fx-padding: 14 0 0 0;" spacing="10">
                                <Button fx:id="btnExportReceipt" text="📄  Export Receipt"
                                        onAction="#handleExportReceipt"
                                        maxWidth="Infinity" styleClass="btn-secondary"/>
                                <Button fx:id="btnCheckout" text="🚪  Checkout Room"
                                        onAction="#handleCheckout"
                                        maxWidth="Infinity" styleClass="btn-danger"/>
                            </VBox>
                        </VBox>
                    </VBox>

                    <!-- Right: Bookings table -->
                    <VBox styleClass="card table-card" spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label text="Booking History" styleClass="card-title"/>
                        <TableView fx:id="bookingTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                            <columns>
                                <TableColumn fx:id="colBookingId"       text="ID"          prefWidth="50"  sortable="true"/>
                                <TableColumn fx:id="colCustomerName"    text="Customer"    prefWidth="130" sortable="true"/>
                                <TableColumn fx:id="colBookingRoom"     text="Room #"      prefWidth="70"  sortable="true"/>
                                <TableColumn fx:id="colCheckIn"         text="Check-In"    prefWidth="100" sortable="true"/>
                                <TableColumn fx:id="colPlannedCheckOut" text="Planned Out" prefWidth="100" sortable="true"/>
                                <TableColumn fx:id="colCheckOut"        text="Actual Out"  prefWidth="100" sortable="true"/>
                                <TableColumn fx:id="colTotalAmount"     text="Total ($)"   prefWidth="90"  sortable="true"/>
                                <TableColumn fx:id="colBookingStatus"   text="Status"      prefWidth="90"  sortable="true"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="📋" style="-fx-font-size:32px;"/>
                                    <Label text="No bookings yet" styleClass="empty-title"/>
                                    <Label text="Use the form to book a room."
                                           styleClass="empty-desc"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
